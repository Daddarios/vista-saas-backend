### Kural: Kayıt silinince dosya da silinir

```csharp
// DateiService.cs
public class DateiService
{
    private readonly IWebHostEnvironment _env;
    private readonly ILogger<DateiService> _logger;

    // Dosya yükle — klasörü otomatik oluşturur
    public async Task<string> HochladenAsync(IFormFile datei, string ordner, Guid entityId)
    {
        var pfad = Path.Combine(_env.ContentRootPath, "Storage", ordner, entityId.ToString());
        Directory.CreateDirectory(pfad);
        var dateiPfad = Path.Combine(pfad, datei.FileName);
        using var stream = File.Create(dateiPfad);
        await datei.CopyToAsync(stream);
        _logger.LogInformation("Dosya yüklendi | {Pfad}", dateiPfad);
        return dateiPfad;
    }

    // Kayıt silinince klasörü tamamen sil
    public void OrdnerLoeschen(string ordner, Guid entityId)
    {
        var pfad = Path.Combine(_env.ContentRootPath, "Storage", ordner, entityId.ToString());
        if (Directory.Exists(pfad))
        {
            Directory.Delete(pfad, recursive: true); // Alt dosyalarla birlikte
            _logger.LogInformation("Klasör silindi | {Pfad}", pfad);
        }
    }
}
```

### Controller'da Entegrasyon

```csharp
[HttpDelete("{id}")]
public async Task<ActionResult> DeleteKunde(Guid id)
{
    var kunde = await _db.Kunden.FindAsync(id);
    if (kunde is null) return NotFound();

    // 1. DB'den sil
    _db.Kunden.Remove(kunde);
    await _db.SaveChangesAsync();

    // 2. Storage klasörünü sil (logo + dosyalar)
    _dateiService.OrdnerLoeschen("kunden", id);

    _logger.LogInformation("Kunde + dosyalar silindi | Id: {Id}", id);
    return NoContent();
}
```

> **Eski hata (Legacy CrmAPP):** Müşteri DB'den siliniyordu ama `logo.png` klasörde kalıyordu.
> **Yeni davranış:** DB silme + klasör silme atomik olarak yapılır.

