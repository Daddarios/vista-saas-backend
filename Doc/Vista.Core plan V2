### Controller'da Kullanım

```csharp
public class KundeController : ControllerBase
{
    private readonly ILogger<KundeController> _logger;

    [HttpDelete("{id}")]
    public async Task<ActionResult> Delete(Guid id)
    {
        try
        {
            var kunde = await _db.Kunden.FindAsync(id);
            if (kunde is null)
            {
                _logger.LogWarning("Kunde bulunamadı | Id: {Id}", id);
                return NotFound();
            }
            _db.Kunden.Remove(kunde);
            await _db.SaveChangesAsync();
            _logger.LogInformation("Kunde silindi | Id: {Id}", id);
            return NoContent();
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Kunde silinemedi | Id: {Id} | Sınıf: KundeController | Metod: Delete", id);
            return StatusCode(500, "Sunucu hatası");
        }
    }
}
```

